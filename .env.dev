# .env.dev — Local development environment
# Copy from .env.example and fill in values

# Telegram Bot (use a test bot token from @BotFather)
TELEGRAM_BOT_TOKEN=test:devtoken_DO_NOT_USE_REAL

# GitHub Webhook secret (generate with: openssl rand -hex 20)
GITHUB_WEBHOOK_SECRET=dev_secret_change_me

# Database
DATABASE_URL=sqlite:///./data/bot_dev.db

# Server
WEBHOOK_HOST=http://localhost:8080
WEBHOOK_PATH=/webhook/github

# Optional: LocalTunnel key for public webhook testing
# Get free key from https://localtunnel.me
LT_KEY=

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
